# URL of the CloudBotWatch ingestion API
# For local dev, point at your local Go API
LOG_ENDPOINT=http://localhost:8080/v1/ingest

# HMAC secret shared with the Go API — minimum 32 characters
LOG_SECRET=dev-hmac-secret-32chars-minimum!!

# Only log requests that include text/html in the Accept header (true/false)
# Set to false to log all asset requests as well
LOG_HTML_ONLY=true

# Fraction of requests to log (0.0–1.0). 1 = log everything, 0.1 = 10% sample
LOG_SAMPLE_RATE=1
